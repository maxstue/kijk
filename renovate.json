{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":semanticCommitTypeAll(build)",
    ":timezone(Europe/Berlin)"
  ],
  "assignees": ["maxstue"],
  "labels": ["dependencies"],
  "minimumReleaseAge": "2 days",
  "rangeStrategy": "bump",
  "schedule": ["before 8am on monday"],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 8am on monday"],
    "commitMessageAction": "refresh"
  },
  "packageRules": [
    {
      "description": "Group GitHub Actions updates.",
      "matchManagers": ["github-actions"],
      "groupName": "github actions",
      "commitMessageTopic": "github actions"
    },
    {
      "description": "Group Docker image updates.",
      "matchManagers": ["dockerfile"],
      "groupName": "docker images",
      "commitMessageTopic": "docker images"
    },
    {
      "description": "Group frontend package patch and minor updates.",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "frontend packages",
      "commitMessageTopic": "frontend packages"
    },
    {
      "description": "Group backend package patch and minor updates.",
      "matchManagers": ["nuget"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "backend packages",
      "commitMessageTopic": "backend packages"
    },
    {
      "description": "Keep frontend and backend major updates isolated for review.",
      "matchManagers": ["npm", "nuget"],
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    }
  ]
}
