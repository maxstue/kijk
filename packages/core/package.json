{
  "name": "@kijk/core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./utils/*": "./src/utils/*.ts",
    "./lib/*": "./src/lib/*.ts",
    "./hooks/*": "./src/hooks/*.ts",
    "./stores/*": "./src/stores/*.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
