{
  "name": "kijk",
  "version": "2026.4.17",
  "private": true,
  "description": "A simple household app made by different technologies.",
  "keywords": [
    "household app"
  ],
  "license": "MIT",
  "author": {
    "name": "Maximilian Stümpfl",
    "url": "https://github.com/maxstue"
  },
  "scripts": {
    "dev": "pnpm run --parallel --filter \"kijk-client\" --filter \"kijk-api\" dev",
    "dev:all": "pnpm run --parallel --filter \"kijk*\" dev",
    "dev:client": "pnpm run --filter \"kijk-client\" dev",
    "dev:api": "pnpm run --filter \"kijk-api\" dev",
    "api:generate": "pnpm run --filter \"kijk-api\" build && pnpm run --filter \"kijk-client\" api:generate",
    "build": "pnpm run --parallel --filter \"kijk*\" build",
    "build:api": "pnpm run --filter \"kijk-api\" build",
    "build:client": "pnpm run --filter \"kijk-client\" build",
    "clean": "pnpm run --parallel --filter \"kijk*\" clean",
    "clean:client": "pnpm run --filter \"kijk-client\" clean:all",
    "clean:all": "pnpm run --parallel -r clean:all && rimraf ./dist ./node_modules ./*.lock ./.eslintcache ",
    "fmt": "pnpm run --parallel --filter \"kijk*\" fmt",
    "fmt:fix": "pnpm run --parallel --filter \"kijk*\" fmt:fix",
    "fmt:all": "pnpm run --parallel -r fmt",
    "fmt:api": "pnpm run --filter \"kijk-api\" fmt",
    "fmt:api:fix": "pnpm run --filter \"kijk-api\" fmt:fix",
    "fmt:api:staged": "dotnet format apps/api/Kijk.slnx --no-restore --verbosity minimal --exclude apps/api/src/Infrastructure/Migrations --include",
    "fmt:api:staged:project": "dotnet format apps/api/Kijk.slnx --no-restore --verbosity minimal --exclude apps/api/src/Infrastructure/Migrations",
    "fmt:client": "pnpm run --filter \"kijk-client\" fmt",
    "fmt:client:fix": "pnpm run --filter \"kijk-client\" fmt:fix",
    "lint": "pnpm run lint:api && pnpm run lint:client",
    "lint:all": "pnpm run --parallel -r lint",
    "lint:api": "pnpm run --filter \"kijk-api\" lint",
    "lint:client": "pnpm run --filter \"kijk-client\" lint",
    "lint:staged": "lint-staged",
    "lint:staged:client": "pnpm --filter kijk-client lint:fix && pnpm --filter kijk-client fmt:fix",
    "lint:staged:config": "pnpm --filter @kijk/config lint:fix && pnpm --filter @kijk/config fmt:fix",
    "lint:staged:core": "pnpm --filter @kijk/core lint:fix && pnpm --filter @kijk/core fmt:fix",
    "lint:staged:ui": "pnpm --filter @kijk/ui lint:fix && pnpm --filter @kijk/ui fmt:fix",
    "start:api": "pnpm run --filter \"kijk-api\" start",
    "prepare": "husky",
    "release": "release-it"
  },
  "lint-staged": {
    "apps/client/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json,css,md,yml,yaml}": "sh -c 'pnpm run lint:staged:client'",
    "packages/config/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json,css,md,yml,yaml}": "sh -c 'pnpm run lint:staged:config'",
    "packages/core/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json,css,md,yml,yaml}": "sh -c 'pnpm run lint:staged:core'",
    "packages/ui/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json,css,md,yml,yaml}": "sh -c 'pnpm run lint:staged:ui'",
    "apps/api/**/*.cs": "pnpm run fmt:api:staged --",
    "apps/api/**/*.{csproj,props,targets,sln,slnx}": "pnpm run fmt:api:staged:project"
  },
  "devDependencies": {
    "@csmith/release-it-calver-plugin": "catalog:",
    "@microsoft/eslint-formatter-sarif": "catalog:",
    "auto-changelog": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "release-it": "catalog:",
    "rimraf": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.2"
}