{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "jsxSingleQuote": true,
  "printWidth": 120,
  "endOfLine": "lf",
  "semi": true,
  "useTabs": false,
  "tabWidth": 2,
  "sortTailwindcss": {
    "functions": [
      "tv",
      "cls",
      "cn"
    ]
  },
  "sortPackageJson": true,
  "ignorePatterns": [
    "cache",
    ".cache",
    "package.json",
    "package-lock.json",
    "public",
    "CHANGELOG.md",
    ".yarn",
    "dist",
    "node_modules",
    ".next",
    "build",
    ".contentlayer",
    "src/routeTree.gen.ts",
    ".gitignore"
  ]
}