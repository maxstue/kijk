# Base
VITE_BASE_API_URL=KIJK_BASE_API_URL
VITE_API_URL="$VITE_BASE_API_URL/api"
# Devtools
VITE_DEVTOOLS_LOGGER="false"
# Auth third party
VITE_CLERK_PUBLISHABLE_KEY=KIJK_CLERK_PUBLISHABLE_KEY
