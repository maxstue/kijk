# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
VITE_BASE_API_URL=KIJK_BASE_API_URL
VITE_API_URL="$VITE_BASE_API_URL/api"
VITE_WEB_URL=KIJK_WEB_URL
# -----------------------------------------------------------------------------
# Devtools
# -----------------------------------------------------------------------------
VITE_DEVTOOLS_LOGGER="false"
# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
VITE_CLERK_PUBLISHABLE_KEY=KIJK_CLERK_PUBLISHABLE_KEY
# -----------------------------------------------------------------------------
# Sentry
# -----------------------------------------------------------------------------
VITE_SENTRY_DSN=KIJK_SENTRY_DSN
SENTRY_ORG="maxstue"
SENTRY_PROJECT="kijk-web"
SENTRY_LOG_LEVEL="info"
SENTRY_ENABLE_TELEMETRY="false"
SENTRY_ENABLE="false"
SENTRY_AUTH_TOKEN=KIJK_SENTRY_AUTH_TOKEN
# -----------------------------------------------------------------------------
# Posthog
# -----------------------------------------------------------------------------
VITE_POSTHOG_KEY=KIJK_POSTHOG_KEY
VITE_POSTHOG_URL=KIJK_POSTHOG_URL
