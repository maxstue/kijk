{
  "name": "kijk-web",
  "version": "0.1.0",
  "private": true,
  "keywords": [
    "nextjs",
    "pnpm",
    "tailwindcss",
    "shadcn/ui"
  ],
  "scripts": {
    "dev": "next dev -p 5003",
    "build": "next build",
    "start": "next start",
    "preview": "next build && next start",
    "lint": "next lint",
    "lint:knip": "knip",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check \"**/*.{ts,tsx,mdx}\" --ignore-path=.gitignore --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,mdx}\" --ignore-path=.gitignore --cache",
    "clean:all": "rimraf ./dist ./stats ./node_modules ./*.lock ./.eslintcache",
    "clean:dedupe": "pnpm dedupe --check",
    "clean:packages": "rimraf ./node_modules",
    "clean:build": "rimraf ./dist ./stats"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.0",
    "@types/node": "^20.14.11",
    "clsx": "^2.1.1",
    "fumadocs-core": "12.5.0",
    "fumadocs-mdx": "8.2.33",
    "fumadocs-ui": "12.5.0",
    "lucide-react": "^0.400.0",
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.3.0",
    "tailwind-variants": "^0.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.3.1",
    "@types/mdx": "^2.0.13",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^6.7.4",
    "@typescript-eslint/parser": "^6.7.4",
    "autoprefixer": "^10.4.19",
    "eslint": "8.50.0",
    "eslint-config-next": "13.5.4",
    "eslint-config-prettier": "^9.0.0",
    "knip": "^2.30.0",
    "postcss": "^8.4.39",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.5.4",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.4"
  }
}
