{
  "name": "kijk-web",
  "version": "0.1.0",
  "private": true,
  "keywords": [
    "nextjs",
    "pnpm",
    "tailwindcss",
    "shadcn/ui"
  ],
  "scripts": {
    "dev": "next dev -p 5003",
    "build": "next build",
    "start": "next start",
    "preview": "next build && next start",
    "lint": "next lint",
    "lint:knip": "knip",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "format:write": "prettier --write \"**/*.{ts,tsx,mdx}\" --ignore-path=.gitignore --cache",
    "format:check": "prettier --check \"**/*.{ts,tsx,mdx}\" --ignore-path=.gitignore --cache",
    "clean:all": "rimraf ./dist ./stats ./node_modules ./*.lock ./.eslintcache",
    "clean:dedupe": "pnpm dedupe --check",
    "clean:packages": "rimraf ./node_modules",
    "clean:build": "rimraf ./dist ./stats",
    "pre-commit": "lint-staged"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "^1.0.4",
    "@radix-ui/react-aspect-ratio": "^1.0.3",
    "@radix-ui/react-avatar": "^1.0.3",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-collapsible": "^1.0.3",
    "@radix-ui/react-context-menu": "^2.1.4",
    "@radix-ui/react-dialog": "^1.0.4",
    "@radix-ui/react-dropdown-menu": "^2.0.5",
    "@radix-ui/react-hover-card": "^1.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-menubar": "^1.0.3",
    "@radix-ui/react-navigation-menu": "^1.1.3",
    "@radix-ui/react-popover": "^1.0.6",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-scroll-area": "^1.0.4",
    "@radix-ui/react-select": "^1.2.2",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.4",
    "@radix-ui/react-toggle": "^1.0.3",
    "@radix-ui/react-tooltip": "^1.0.6",
    "@sentry/nextjs": "^7.56.0",
    "@t3-oss/env-nextjs": "^0.4.1",
    "@vercel/analytics": "^1.0.1",
    "autoprefixer": "10.4.14",
    "class-variance-authority": "^0.6.0",
    "clsx": "^1.2.1",
    "dotenv-cli": "^7.2.1",
    "lucide-react": "^0.246.0",
    "next": "13.4.6",
    "next-themes": "^0.2.1",
    "postcss": "8.4.24",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwind-merge": "^1.13.2",
    "tailwindcss": "3.3.2",
    "tailwindcss-animate": "^1.0.6",
    "ts-node": "^10.9.1",
    "typescript": "5.1.3"
  },
  "devDependencies": {
    "@builder.io/partytown": "^0.8.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.0.2",
    "@types/node": "20.3.1",
    "@types/react": "18.2.13",
    "@types/react-dom": "18.2.6",
    "@typescript-eslint/eslint-plugin": "^5.60.0",
    "@typescript-eslint/parser": "^5.60.0",
    "eslint": "8.43.0",
    "eslint-config-next": "13.4.6",
    "eslint-config-prettier": "^8.8.0",
    "husky": "^8.0.3",
    "knip": "^2.14.1",
    "prettier": "^2.8.8",
    "prettier-plugin-tailwindcss": "^0.3.0",
    "rimraf": "^5.0.1"
  }
