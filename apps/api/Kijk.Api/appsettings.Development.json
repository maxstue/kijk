{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=5432;Database=kijk;UserName=postgres;Password=secret;"
  },
  "Serilog": {
    "LevelSwitches": {
      "ConsoleSwitch": "Information"
    },
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "System": "Warning",
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.IdentityModel.LoggingExtensions.IdentityLoggerAdapter ": "Warning"
      }
    },
    "Using": ["Serilog.Sinks.Console"],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss.fff}] [{Level:u4}] [{SourceContext}] {Message}{NewLine}{Exception}",
          "levelSwitch": "$ConsoleSwitch"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },
  "Sentry": {
    "Dsn": "",
    "SendDefaultPii": false,
    "MaxRequestBodySize": "Always",
    "MinimumBreadcrumbLevel": "Debug",
    "MinimumEventLevel": "Warning",
    "MaxBreadcrumbs": 50,
    "AttachStackTrace": true,
    "Debug": true,
    "DiagnosticLevel": "Error",
    "TracesSampleRate": 1.0
  }
}
