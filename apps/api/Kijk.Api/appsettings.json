{
  "Auth": {
    "Authority":"",
    "AuthorizedParty":"http://localhost:5004"
  },
  "AllowedHosts": "*",
  "Cors": [
    "http://localhost:5004",
    "https://kijk-client.vercel.app",
    "https://kijk-client.fly.dev",
    "https://kijk.justmax.xyz"
  ],
  "Serilog": {
    "LevelSwitches": {
      "ConsoleSwitch": "Information"
    },
    "Filter": [
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "RequestPath like '%swagger%'"
        }
      },
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "RequestMethod like '%OPTIONS%'"
        }
      }
    ],
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Expressions"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm:ss.fff}] [{Level:u4}] [{SourceContext}] {CorrelationId} {Message}{NewLine}{Exception}",
          "levelSwitch": "$ConsoleSwitch"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  }
}
