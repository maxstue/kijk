  "components": {
    "schemas": {
      "CategoryCreatorType": {
        "enum": [
          "Default",
          "User"
        ]
      },
      "CategoryDto": {
        "required": [
          "id",
          "name",
          "color",
          "type",
          "creatorType"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "type": {
            "$ref": "#/components/schemas/CategoryType"
          },
          "creatorType": {
            "$ref": "#/components/schemas/CategoryCreatorType"
          }
        },
        "nullable": true
      },
      "CategoryDto2": {
        "required": [
          "id",
          "name",
          "color",
          "type",
          "creatorType"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "type": {
            "$ref": "#/components/schemas/CategoryType"
          },
          "creatorType": {
            "$ref": "#/components/schemas/CategoryCreatorType"
          }
        }
      },
      "CategoryType": {
        "enum": [
          "Expense",
          "Income",
          "Other"
        ]
      },
      "CreateCategoryRequest": {
        "required": [
          "name",
          "color",
          "type"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        }
      },
      "CreateEnergyConsumptionRequest": {
        "required": [
          "name",
          "value",
          "type",
          "date"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "value": {
            "type": "number",
            "format": "double"
          },
          "type": {
            "$ref": "#/components/schemas/EnergyConsumptionType"
          },
          "date": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateTransactionRequest": {
        "required": [
          "name",
          "amount",
          "type",
          "executedAt",
          "accountId",
          "categoryId"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "amount": {
            "type": "number",
            "format": "double"
          },
          "type": {
            "$ref": "#/components/schemas/TransactionType"
          },
          "executedAt": {
            "type": "string",
            "format": "date-time"
          },
          "accountId": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "categoryId": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          }
        }
      },
      "EnergyConsumptionResponse": {
        "required": [
          "id",
          "name",
          "description",
          "value",
          "type",
          "date"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "value": {
            "type": "number",
            "format": "double"
          },
          "type": {
            "$ref": "#/components/schemas/EnergyConsumptionType"
          },
          "date": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "EnergyConsumptionType": {
        "enum": [
          "Electricity",
          "Gas",
          "Water"
        ]
      },
      "Error": {
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/ErrorType"
          },
          "code": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "ErrorType": {
        "enum": [
          "Validation",
          "Conflict",
