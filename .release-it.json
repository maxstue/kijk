{
  "git": {
    "requireBranch": "main",
    "changelog": "pnpm exec auto-changelog --stdout --commit-limit false --unreleased --template https://raw.githubusercontent.com/release-it/release-it/main/templates/changelog-compact.hbs",
    "commitMessage": "chore: release ${version} [skip ci]"
  },
  "hooks": {
    "after:bump": "pnpm exec auto-changelog -p --commit-limit false"
  },
  "github": {
    "release": true,
    "releaseName": "${version}"
  },
  "plugins": {
    "@csmith/release-it-calver-plugin": {
      "cycle": "month",
      "increment": "calendar"
    }
  },
  "npm": {
    "publish": false,
    "versionArgs": ["--force"]
  }
}
