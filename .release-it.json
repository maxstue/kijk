{
  "git": {
    "requireBranch": "main",
    "commitMessage": "chore: release ${version}"
  },
  "hooks": {
    "before:init": ["pnpm build"],
    "after:bump": "pnpx auto-changelog -p"
  },
  "github": {
    "release": true,
    "releaseName": "v${version}"
  },
  "plugins": {
    "@csmith/release-it-calver-plugin": {
      "format": "yyyy.mm.minor",
      "increment": "calendar"
    }
  },
  "npm": {
    "publish": false
  }
}
